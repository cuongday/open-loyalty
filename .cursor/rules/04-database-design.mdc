# Database Design Rules

## Database Strategy Overview

### 1. Database per Service Pattern
Each microservice owns its database to ensure:
- **Data isolation** and service autonomy
- **Independent scaling** of data stores
- **Technology diversity** based on service needs
- **Fault isolation** to prevent cascading failures

### 2. Database Technology Selection
```yaml
PostgreSQL:
  Use for: Transactional data requiring ACID compliance
  Services: User, Customer, Account, Campaign, Transaction, Level, Earning Rules
  Features: Strong consistency, complex queries, referential integrity

MongoDB:
  Use for: Document-based data and flexible schemas
  Services: Analytics, Segment, Notification
  Features: Flexible schema, horizontal scaling, complex aggregations

Redis:
  Use for: Caching, session storage, rate limiting
  Services: All services for caching layer
  Features: In-memory performance, pub/sub, distributed locks

Elasticsearch:
  Use for: Search, logging, analytics
  Services: Analytics, Logging infrastructure
  Features: Full-text search, aggregations, real-time analytics
```

## PostgreSQL Database Design

### 1. User Service Database
```sql
-- Users table
CREATE TABLE users (
    user_id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    email VARCHAR(255) UNIQUE NOT NULL,
    password_hash VARCHAR(255) NOT NULL,
    first_name VARCHAR(100) NOT NULL,
    last_name VARCHAR(100) NOT NULL,
    phone VARCHAR(20),
    status VARCHAR(20) DEFAULT 'ACTIVE',
    created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW(),
    updated_at TIMESTAMP WITH TIME ZONE DEFAULT NOW(),
    last_login_at TIMESTAMP WITH TIME ZONE
);

-- User roles table
CREATE TABLE user_roles (
    user_id UUID REFERENCES users(user_id),
    role VARCHAR(50) NOT NULL,
    granted_at TIMESTAMP WITH TIME ZONE DEFAULT NOW(),
    granted_by UUID REFERENCES users(user_id),
    PRIMARY KEY (user_id, role)
);

-- User sessions table (Redis alternative)
CREATE TABLE user_sessions (
    session_id UUID PRIMARY KEY,
    user_id UUID REFERENCES users(user_id),
    access_token_hash VARCHAR(255),
    refresh_token_hash VARCHAR(255),
    expires_at TIMESTAMP WITH TIME ZONE,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW(),
    last_accessed_at TIMESTAMP WITH TIME ZONE DEFAULT NOW()
);

-- Indexes
CREATE INDEX idx_users_email ON users(email);
CREATE INDEX idx_users_status ON users(status);
CREATE INDEX idx_user_sessions_user_id ON user_sessions(user_id);
CREATE INDEX idx_user_sessions_expires_at ON user_sessions(expires_at);
```

### 2. Customer Service Database
```sql
-- Customers table
CREATE TABLE customers (
    customer_id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    user_id UUID UNIQUE, -- Reference to user service
    customer_number VARCHAR(50) UNIQUE,
    first_name VARCHAR(100) NOT NULL,
    last_name VARCHAR(100) NOT NULL,
    email VARCHAR(255) UNIQUE NOT NULL,
    phone VARCHAR(20),
    date_of_birth DATE,
    gender VARCHAR(10),
    status VARCHAR(20) DEFAULT 'ACTIVE',
    registration_date TIMESTAMP WITH TIME ZONE DEFAULT NOW(),
    last_activity_date TIMESTAMP WITH TIME ZONE,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW(),
    updated_at TIMESTAMP WITH TIME ZONE DEFAULT NOW()
);

-- Customer addresses table
CREATE TABLE customer_addresses (
    address_id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    customer_id UUID REFERENCES customers(customer_id),
    address_type VARCHAR(20) DEFAULT 'PRIMARY',
    street_address VARCHAR(255),
    city VARCHAR(100),
    state VARCHAR(100),
    postal_code VARCHAR(20),
    country VARCHAR(100),
    is_default BOOLEAN DEFAULT FALSE,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW()
);

-- Customer preferences table
CREATE TABLE customer_preferences (
    customer_id UUID PRIMARY KEY REFERENCES customers(customer_id),
    email_notifications BOOLEAN DEFAULT TRUE,
    sms_notifications BOOLEAN DEFAULT FALSE,
    push_notifications BOOLEAN DEFAULT TRUE,
    language VARCHAR(10) DEFAULT 'en',
    currency VARCHAR(3) DEFAULT 'USD',
    timezone VARCHAR(50) DEFAULT 'UTC',
    preferences_data JSONB,
    updated_at TIMESTAMP WITH TIME ZONE DEFAULT NOW()
);

-- Indexes
CREATE INDEX idx_customers_email ON customers(email);
CREATE INDEX idx_customers_status ON customers(status);
CREATE INDEX idx_customers_registration_date ON customers(registration_date);
CREATE INDEX idx_customer_addresses_customer_id ON customer_addresses(customer_id);
```

### 3. Account Service Database
```sql
-- Accounts table
CREATE TABLE accounts (
    account_id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    customer_id UUID UNIQUE NOT NULL, -- Reference to customer service
    current_balance DECIMAL(15,2) DEFAULT 0.00,
    lifetime_earned DECIMAL(15,2) DEFAULT 0.00,
    lifetime_spent DECIMAL(15,2) DEFAULT 0.00,
    lifetime_expired DECIMAL(15,2) DEFAULT 0.00,
    status VARCHAR(20) DEFAULT 'ACTIVE',
    created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW(),
    updated_at TIMESTAMP WITH TIME ZONE DEFAULT NOW(),
    
    CONSTRAINT chk_balance_positive CHECK (current_balance >= 0)
);

-- Points transactions table
CREATE TABLE points_transactions (
    transaction_id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    account_id UUID REFERENCES accounts(account_id),
    transaction_type VARCHAR(20) NOT NULL, -- EARN, SPEND, EXPIRE, ADJUST
    points_amount DECIMAL(15,2) NOT NULL,
    balance_after DECIMAL(15,2) NOT NULL,
    description VARCHAR(500),
    reference_id UUID, -- Reference to earning rule, campaign, etc.
    reference_type VARCHAR(50), -- EARNING_RULE, CAMPAIGN, MANUAL, etc.
    created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW(),
    expires_at TIMESTAMP WITH TIME ZONE,
    
    CONSTRAINT chk_points_amount CHECK (
        (transaction_type = 'SPEND' AND points_amount < 0) OR
        (transaction_type IN ('EARN', 'ADJUST') AND points_amount > 0) OR
        (transaction_type = 'EXPIRE' AND points_amount <= 0)
    )
);

-- Points expiration tracking
CREATE TABLE points_expiration (
    expiration_id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    account_id UUID REFERENCES accounts(account_id),
    points_amount DECIMAL(15,2) NOT NULL,
    earned_date TIMESTAMP WITH TIME ZONE NOT NULL,
    expires_at TIMESTAMP WITH TIME ZONE NOT NULL,
    status VARCHAR(20) DEFAULT 'ACTIVE', -- ACTIVE, EXPIRED, USED
    created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW()
);

-- Indexes
CREATE INDEX idx_accounts_customer_id ON accounts(customer_id);
CREATE INDEX idx_points_transactions_account_id ON points_transactions(account_id);
CREATE INDEX idx_points_transactions_created_at ON points_transactions(created_at);
CREATE INDEX idx_points_transactions_type ON points_transactions(transaction_type);
CREATE INDEX idx_points_expiration_account_id ON points_expiration(account_id);
CREATE INDEX idx_points_expiration_expires_at ON points_expiration(expires_at);
```

### 4. Campaign Service Database
```sql
-- Campaigns table
CREATE TABLE campaigns (
    campaign_id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    name VARCHAR(255) NOT NULL,
    description TEXT,
    short_description VARCHAR(500),
    terms_and_conditions TEXT,
    usage_instructions TEXT,
    campaign_type VARCHAR(50) NOT NULL, -- DISCOUNT, GIFT, EVENT, DELIVERY
    reward_value DECIMAL(15,2),
    points_cost DECIMAL(15,2) NOT NULL DEFAULT 0,
    status VARCHAR(20) DEFAULT 'DRAFT', -- DRAFT, ACTIVE, INACTIVE, EXPIRED
    is_unlimited BOOLEAN DEFAULT FALSE,
    usage_limit INTEGER,
    limit_per_customer INTEGER DEFAULT 1,
    start_date TIMESTAMP WITH TIME ZONE,
    end_date TIMESTAMP WITH TIME ZONE,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW(),
    updated_at TIMESTAMP WITH TIME ZONE DEFAULT NOW()
);

-- Campaign eligibility rules
CREATE TABLE campaign_eligibility (
    eligibility_id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    campaign_id UUID REFERENCES campaigns(campaign_id),
    rule_type VARCHAR(50) NOT NULL, -- LEVEL, SEGMENT, CUSTOM
    rule_value VARCHAR(255) NOT NULL,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW()
);

-- Coupons table
CREATE TABLE coupons (
    coupon_id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    campaign_id UUID REFERENCES campaigns(campaign_id),
    coupon_code VARCHAR(100) UNIQUE NOT NULL,
    customer_id UUID, -- Reference to customer service
    issued_at TIMESTAMP WITH TIME ZONE,
    used_at TIMESTAMP WITH TIME ZONE,
    expires_at TIMESTAMP WITH TIME ZONE,
    status VARCHAR(20) DEFAULT 'AVAILABLE', -- AVAILABLE, ISSUED, USED, EXPIRED
    created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW()
);

-- Campaign redemptions table
CREATE TABLE campaign_redemptions (
    redemption_id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    campaign_id UUID REFERENCES campaigns(campaign_id),
    customer_id UUID NOT NULL, -- Reference to customer service
    coupon_id UUID REFERENCES coupons(coupon_id),
    points_cost DECIMAL(15,2) NOT NULL,
    redeemed_at TIMESTAMP WITH TIME ZONE DEFAULT NOW(),
    status VARCHAR(20) DEFAULT 'COMPLETED' -- COMPLETED, CANCELLED, REFUNDED
);

-- Indexes
CREATE INDEX idx_campaigns_status ON campaigns(status);
CREATE INDEX idx_campaigns_dates ON campaigns(start_date, end_date);
CREATE INDEX idx_campaign_eligibility_campaign_id ON campaign_eligibility(campaign_id);
CREATE INDEX idx_coupons_campaign_id ON coupons(campaign_id);
CREATE INDEX idx_coupons_customer_id ON coupons(customer_id);
CREATE INDEX idx_coupons_code ON coupons(coupon_code);
CREATE INDEX idx_campaign_redemptions_customer_id ON campaign_redemptions(customer_id);
```

### 5. Transaction Service Database
```sql
-- Transactions table
CREATE TABLE transactions (
    transaction_id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    external_transaction_id VARCHAR(255) UNIQUE,
    customer_id UUID NOT NULL, -- Reference to customer service
    transaction_date TIMESTAMP WITH TIME ZONE NOT NULL,
    total_amount DECIMAL(15,2) NOT NULL,
    currency VARCHAR(3) DEFAULT 'USD',
    status VARCHAR(20) DEFAULT 'PENDING', -- PENDING, COMPLETED, CANCELLED, REFUNDED
    channel VARCHAR(50), -- ONLINE, POS, MOBILE, API
    store_id VARCHAR(100),
    pos_id VARCHAR(100),
    created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW(),
    updated_at TIMESTAMP WITH TIME ZONE DEFAULT NOW()
);

-- Transaction items table
CREATE TABLE transaction_items (
    item_id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    transaction_id UUID REFERENCES transactions(transaction_id),
    product_sku VARCHAR(255) NOT NULL,
    product_name VARCHAR(500),
    category VARCHAR(255),
    quantity DECIMAL(10,2) NOT NULL,
    unit_price DECIMAL(15,2) NOT NULL,
    total_price DECIMAL(15,2) NOT NULL,
    discount_amount DECIMAL(15,2) DEFAULT 0.00,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW()
);

-- Transaction metadata table
CREATE TABLE transaction_metadata (
    transaction_id UUID PRIMARY KEY REFERENCES transactions(transaction_id),
    payment_method VARCHAR(50),
    delivery_cost DECIMAL(15,2) DEFAULT 0.00,
    tax_amount DECIMAL(15,2) DEFAULT 0.00,
    discount_amount DECIMAL(15,2) DEFAULT 0.00,
    coupon_code VARCHAR(100),
    notes TEXT,
    metadata JSONB,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW()
);

-- Indexes
CREATE INDEX idx_transactions_customer_id ON transactions(customer_id);
CREATE INDEX idx_transactions_date ON transactions(transaction_date);
CREATE INDEX idx_transactions_status ON transactions(status);
CREATE INDEX idx_transactions_external_id ON transactions(external_transaction_id);
CREATE INDEX idx_transaction_items_transaction_id ON transaction_items(transaction_id);
CREATE INDEX idx_transaction_items_sku ON transaction_items(product_sku);
```

