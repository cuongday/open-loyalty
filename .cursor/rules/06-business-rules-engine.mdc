### 2. Rule Engine Service
```java
@Service
@Slf4j
public class RuleEngineService {
    
    private final KieSession kieSession;
    private final RuleExecutionAuditor ruleAuditor;
    
    public RuleEngineService(KieSession kieSession, RuleExecutionAuditor ruleAuditor) {
        this.kieSession = kieSession;
        this.ruleAuditor = ruleAuditor;
    }
    
    public <T> RuleExecutionResult<T> executeRules(T fact, String agenda) {
        long startTime = System.currentTimeMillis();
        
        try {
            // Clear previous facts
            kieSession.getObjects().forEach(kieSession::delete);
            
            // Insert new fact
            FactHandle factHandle = kieSession.insert(fact);
            
            // Set agenda filter if provided
            if (agenda != null) {
                kieSession.getAgenda().getAgendaGroup(agenda).setFocus();
            }
            
            // Execute rules
            int rulesExecuted = kieSession.fireAllRules();
            
            // Get updated fact
            T updatedFact = (T) kieSession.getObject(factHandle);
            
            long executionTime = System.currentTimeMillis() - startTime;
            
            RuleExecutionResult<T> result = RuleExecutionResult.<T>builder()
                .fact(updatedFact)
                .rulesExecuted(rulesExecuted)
                .executionTimeMs(executionTime)
                .success(true)
                .build();
                
            // Audit rule execution
            ruleAuditor.auditExecution(fact, result);
            
            return result;
            
        } catch (Exception e) {
            log.error("Rule execution failed", e);
            
            return RuleExecutionResult.<T>builder()
                .fact(fact)
                .rulesExecuted(0)
                .executionTimeMs(System.currentTimeMillis() - startTime)
                .success(false)
                .errorMessage(e.getMessage())
                .build();
        }
    }
    
    public void reloadRules() {
        // Dynamic rule reloading
        KieContainer kieContainer = kieSession.getKieBase().getKieContainer();
        // Implementation for hot reloading rules
    }
}
