### 3. Campaign Eligibility Rules
```drools
// Campaign eligibility for VIP customers
rule "VIP Campaign Eligibility"
agenda-group "campaign-eligibility"
when
    $eligibility : CampaignEligibilityFact(!eligible)
    $customer : CustomerFact(segment == "VIP") from $eligibility.customer
    $campaign : CampaignFact(targetSegment == "VIP") from $eligibility.campaign
then
    $eligibility.setEligible(true);
    $eligibility.setReason("VIP segment eligibility");
    update($eligibility);
end

// Level-based campaign eligibility
rule "Gold Level Campaign Access"
agenda-group "campaign-eligibility"
when
    $eligibility : CampaignEligibilityFact(!eligible)
    $customer : CustomerFact(level == "GOLD" || level == "PLATINUM") from $eligibility.customer
    $campaign : CampaignFact(minimumLevel == "GOLD") from $eligibility.campaign
then
    $eligibility.setEligible(true);
    $eligibility.setReason("Gold level or higher eligibility");
    update($eligibility);
end

// Spending threshold eligibility
rule "High Spender Campaign"
agenda-group "campaign-eligibility"
when
    $eligibility : CampaignEligibilityFact(!eligible)
    $customer : CustomerFact() from $eligibility.customer
    $campaign : CampaignFact() from $eligibility.campaign
    eval($customer.getTotalSpent().compareTo($campaign.getMinimumSpend()) >= 0)
then
    $eligibility.setEligible(true);
    $eligibility.setReason("Minimum spend threshold met: $" + $campaign.getMinimumSpend());
    update($eligibility);
end

// Exclusion rule for suspended customers
rule "Exclude Suspended Customers"
agenda-group "campaign-eligibility"
when
    $eligibility : CampaignEligibilityFact(eligible)
    $customer : CustomerFact(status == "SUSPENDED") from $eligibility.customer
then
    $eligibility.setEligible(false);
    $eligibility.setReason("Customer account suspended");
    update($eligibility);
end
