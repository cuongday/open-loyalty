## A/B Testing for Rules

### 1. Rule Variant Testing
```java
@Service
public class RuleABTestingService {
    
    private final RuleVariantRepository ruleVariantRepository;
    private final RuleEngineService ruleEngineService;
    private final ABTestMetricsCollector metricsCollector;
    
    public void createABTest(CreateABTestRequest request) {
        ABTest abTest = ABTest.builder()
            .name(request.getName())
            .baseRuleId(request.getBaseRuleId())
            .variantRuleId(request.getVariantRuleId())
            .trafficSplitPercentage(request.getTrafficSplit()) // e.g., 50% each
            .startDate(request.getStartDate())
            .endDate(request.getEndDate())
            .status(ABTestStatus.ACTIVE)
            .build();
            
        abTestRepository.save(abTest);
    }
    
    public RuleExecutionResult executeWithABTest(String customerId, Object fact, String ruleType) {
        ABTest activeTest = getActiveABTest(ruleType);
        
        if (activeTest == null) {
            // No A/B test, use default rule
            return ruleEngineService.executeRules(fact, ruleType);
        }
        
        // Determine which variant to use based on customer ID hash
        boolean useVariant = shouldUseVariant(customerId, activeTest.getTrafficSplitPercentage());
        
        String ruleId = useVariant ? activeTest.getVariantRuleId() : activeTest.getBaseRuleId();
        RuleExecutionResult result = executeSpecificRule(fact, ruleId);
        
        // Collect metrics for A/B test analysis
        ABTestMetric metric = ABTestMetric.builder()
            .abTestId(activeTest.getId())
            .customerId(customerId)
            .variant(useVariant ? "B" : "A")
            .ruleId(ruleId)
            .pointsEarned(extractPointsFromResult(result))
            .executionTime(result.getExecutionTimeMs())
            .timestamp(LocalDateTime.now())
            .build();
            
        metricsCollector.collectMetric(metric);
        
        return result;
    }
    
    private boolean shouldUseVariant(String customerId, int trafficSplitPercentage) {
        // Use consistent hashing to assign customers to variants
        int hash = Math.abs(customerId.hashCode() % 100);
        return hash < trafficSplitPercentage;
    }
    
    public ABTestReport generateABTestReport(String abTestId) {
        List<ABTestMetric> metrics = abTestMetricsRepository.findByAbTestId(abTestId);
        
        // Calculate statistics for each variant
        Map<String, List<ABTestMetric>> variantMetrics = metrics.stream()
            .collect(Collectors.groupingBy(ABTestMetric::getVariant));
            
        ABTestVariantStats variantAStats = calculateVariantStats(variantMetrics.get("A"));
        ABTestVariantStats variantBStats = calculateVariantStats(variantMetrics.get("B"));
        
        // Perform statistical significance test
        double pValue = performTTest(variantAStats, variantBStats);
        boolean isSignificant = pValue < 0.05;
        
        return ABTestReport.builder()
            .abTestId(abTestId)
            .variantAStats(variantAStats)
            .variantBStats(variantBStats)
            .pValue(pValue)
            .isStatisticallySignificant(isSignificant)
            .recommendation(generateRecommendation(variantAStats, variantBStats, isSignificant))
            .build();
    }
}
