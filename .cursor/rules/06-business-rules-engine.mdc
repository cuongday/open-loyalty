### 2. Drools Rule Examples
```drools
// Points for purchase amount rule
rule "Points for Purchase Amount"
agenda-group "earning-rules"
when
    $rule : EarningRuleFact(ruleType == "POINTS_FOR_AMOUNT", !ruleApplied)
    $transaction : TransactionFact() from $rule.transaction
    $customer : CustomerFact() from $rule.customer
    eval($transaction.getTotalAmount().compareTo(new BigDecimal("10.00")) >= 0)
then
    int points = $transaction.getTotalAmount().multiply(new BigDecimal("0.1")).intValue();
    $rule.setPointsEarned(points);
    $rule.setRuleApplied(true);
    $rule.setReason("Earned " + points + " points for purchase amount: $" + $transaction.getTotalAmount());
    update($rule);
end

// Bonus points for first purchase
rule "First Purchase Bonus"
agenda-group "earning-rules"
when
    $rule : EarningRuleFact(ruleType == "FIRST_PURCHASE_BONUS", !ruleApplied)
    $customer : CustomerFact(transactionCount == 1) from $rule.customer
then
    $rule.setPointsEarned(100);
    $rule.setRuleApplied(true);
    $rule.setReason("First purchase bonus: 100 points");
    update($rule);
end

// Level-based multiplier rule
rule "Gold Level Multiplier"
agenda-group "earning-rules"
when
    $rule : EarningRuleFact(ruleType == "LEVEL_MULTIPLIER", !ruleApplied)
    $customer : CustomerFact(level == "GOLD") from $rule.customer
    $transaction : TransactionFact() from $rule.transaction
then
    int basePoints = $transaction.getTotalAmount().multiply(new BigDecimal("0.1")).intValue();
    int bonusPoints = (int) (basePoints * 0.5); // 50% bonus for Gold level
    $rule.setPointsEarned(bonusPoints);
    $rule.setRuleApplied(true);
    $rule.setReason("Gold level bonus: " + bonusPoints + " extra points");
    update($rule);
end

// Product category bonus rule
rule "Electronics Category Bonus"
agenda-group "earning-rules"
when
    $rule : EarningRuleFact(ruleType == "CATEGORY_BONUS", !ruleApplied)
    $transaction : TransactionFact() from $rule.transaction
    $item : TransactionItemFact(category == "ELECTRONICS") from $transaction.items
then
    int bonusPoints = $item.getTotalPrice().multiply(new BigDecimal("0.05")).intValue();
    $rule.setPointsEarned($rule.getPointsEarned() + bonusPoints);
    $rule.setRuleApplied(true);
    $rule.setReason("Electronics category bonus: " + bonusPoints + " points");
    update($rule);
end

// Weekend purchase bonus
rule "Weekend Purchase Bonus"
agenda-group "earning-rules"
when
    $rule : EarningRuleFact(ruleType == "WEEKEND_BONUS", !ruleApplied)
    $transaction : TransactionFact() from $rule.transaction
    eval(isWeekend($transaction.getTransactionDate()))
then
    int bonusPoints = 50;
    $rule.setPointsEarned(bonusPoints);
    $rule.setRuleApplied(true);
    $rule.setReason("Weekend purchase bonus: " + bonusPoints + " points");
    update($rule);
end

// Minimum order value rule
rule "Minimum Order for Points"
agenda-group "earning-rules"
when
    $rule : EarningRuleFact(ruleType == "POINTS_FOR_AMOUNT", !ruleApplied)
    $transaction : TransactionFact() from $rule.transaction
    eval($transaction.getTotalAmount().compareTo(new BigDecimal("25.00")) < 0)
then
    $rule.setPointsEarned(0);
    $rule.setRuleApplied(true);
    $rule.setReason("Minimum order value of $25.00 required for points");
    update($rule);
end
