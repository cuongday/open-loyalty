## Rule Performance Monitoring

### 1. Rule Execution Metrics
```java
@Component
public class RuleExecutionAuditor {
    
    private final MeterRegistry meterRegistry;
    private final RuleExecutionLogRepository logRepository;
    
    public void auditExecution(Object fact, RuleExecutionResult<?> result) {
        // Record metrics
        Timer.Sample sample = Timer.start(meterRegistry);
        sample.stop(Timer.builder("rule.execution.time")
            .tag("rule.type", extractRuleType(fact))
            .tag("success", String.valueOf(result.isSuccess()))
            .register(meterRegistry));
            
        Counter.builder("rule.execution.count")
            .tag("rule.type", extractRuleType(fact))
            .tag("rules.executed", String.valueOf(result.getRulesExecuted()))
            .register(meterRegistry)
            .increment();
            
        // Log execution details
        RuleExecutionLog log = RuleExecutionLog.builder()
            .factType(fact.getClass().getSimpleName())
            .rulesExecuted(result.getRulesExecuted())
            .executionTimeMs(result.getExecutionTimeMs())
            .success(result.isSuccess())
            .errorMessage(result.getErrorMessage())
            .timestamp(LocalDateTime.now())
            .build();
            
        logRepository.save(log);
    }
    
    public RulePerformanceReport generatePerformanceReport(LocalDateTime startDate, LocalDateTime endDate) {
        List<RuleExecutionLog> logs = logRepository.findByTimestampBetween(startDate, endDate);
        
        return RulePerformanceReport.builder()
            .totalExecutions(logs.size())
            .averageExecutionTime(calculateAverageExecutionTime(logs))
            .successRate(calculateSuccessRate(logs))
            .topSlowRules(findTopSlowRules(logs))
            .errorSummary(generateErrorSummary(logs))
            .build();
    }
}
