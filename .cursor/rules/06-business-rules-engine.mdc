### 2. Rule Health Monitoring
```java
@Component
@Scheduled(fixedRate = 300000) // 5 minutes
public class RuleHealthMonitor {
    
    private final RuleRepository ruleRepository;
    private final AlertService alertService;
    
    public void monitorRuleHealth() {
        List<Rule> activeRules = ruleRepository.findByStatus(RuleStatus.ACTIVE);
        
        for (Rule rule : activeRules) {
            RuleHealthCheck healthCheck = performHealthCheck(rule);
            
            if (!healthCheck.isHealthy()) {
                alertService.sendAlert(AlertType.RULE_HEALTH_ISSUE, 
                    "Rule " + rule.getName() + " health check failed: " + 
                    healthCheck.getIssues());
            }
        }
    }
    
    private RuleHealthCheck performHealthCheck(Rule rule) {
        List<String> issues = new ArrayList<>();
        
        // Check rule compilation
        try {
            ruleCompiler.compile(rule.getContent());
        } catch (Exception e) {
            issues.add("Compilation failed: " + e.getMessage());
        }
        
        // Check rule performance
        RulePerformanceMetrics metrics = getRecentPerformanceMetrics(rule.getId());
        if (metrics.getAverageExecutionTime() > 1000) { // > 1 second
            issues.add("High execution time: " + metrics.getAverageExecutionTime() + "ms");
        }
        
        if (metrics.getErrorRate() > 0.05) { // > 5% error rate
            issues.add("High error rate: " + (metrics.getErrorRate() * 100) + "%");
        }
        
        return RuleHealthCheck.builder()
            .ruleId(rule.getId())
            .healthy(issues.isEmpty())
            .issues(issues)
            .checkTime(LocalDateTime.now())
            .build();
    }
}
