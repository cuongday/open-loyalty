### 2. Rule Testing Framework
```java
@Service
public class RuleTestingService {
    
    private final KieSession testKieSession;
    
    public RuleTestResult testRule(String ruleContent, Object testFact) {
        // Create isolated test session
        KieServices kieServices = KieServices.Factory.get();
        KieFileSystem kieFileSystem = kieServices.newKieFileSystem();
        
        // Add test rule
        kieFileSystem.write("src/main/resources/test-rule.drl", ruleContent);
        
        KieBuilder kieBuilder = kieServices.newKieBuilder(kieFileSystem);
        kieBuilder.buildAll();
        
        if (kieBuilder.getResults().hasMessages(Level.ERROR)) {
            return RuleTestResult.builder()
                .success(false)
                .errorMessage("Compilation failed: " + kieBuilder.getResults().toString())
                .build();
        }
        
        KieContainer kieContainer = kieServices.newKieContainer(
            kieBuilder.getKieModule().getReleaseId());
        KieSession testSession = kieContainer.newKieSession();
        
        try {
            // Insert test fact
            testSession.insert(testFact);
            
            // Execute rules
            int rulesExecuted = testSession.fireAllRules();
            
            return RuleTestResult.builder()
                .success(true)
                .rulesExecuted(rulesExecuted)
                .resultFact(testFact)
                .build();
                
        } finally {
            testSession.dispose();
        }
    }
    
    public List<RuleTestResult> runRuleTestSuite(String ruleId) {
        Rule rule = ruleRepository.findById(ruleId)
            .orElseThrow(() -> new RuleNotFoundException("Rule not found"));
            
        List<RuleTestCase> testCases = ruleTestCaseRepository.findByRuleId(ruleId);
        List<RuleTestResult> results = new ArrayList<>();
        
        for (RuleTestCase testCase : testCases) {
            RuleTestResult result = testRule(rule.getContent(), testCase.getTestFact());
            result.setTestCaseName(testCase.getName());
            results.add(result);
        }
        
        return results;
    }
}
