// Custom permission evaluator
@Component
public class CustomPermissionEvaluator implements PermissionEvaluator {
    
    @Override
    public boolean hasPermission(Authentication authentication, Object targetDomainObject, Object permission) {
        if (authentication == null || !(permission instanceof String)) {
            return false;
        }
        
        String permissionString = (String) permission;
        return hasPrivilege(authentication, permissionString, targetDomainObject);
    }
    
    private boolean hasPrivilege(Authentication auth, String permission, Object target) {
        Collection<? extends GrantedAuthority> authorities = auth.getAuthorities();
        
        for (GrantedAuthority authority : authorities) {
            if (authority.getAuthority().equals(permission)) {
                return true;
            }
        }
        
        // Check for customer-specific permissions
        if (target instanceof Customer) {
            Customer customer = (Customer) target;
            CustomUserDetails userDetails = (CustomUserDetails) auth.getPrincipal();
            
            // Customer can only access their own data
            return customer.getCustomerId().equals(userDetails.getCustomerId());
        }
        
        return false;
    }
}
