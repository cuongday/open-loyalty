### 3. API Key Management
```java
@Service
public class ApiKeyService {
    
    private final ApiKeyRepository apiKeyRepository;
    private final RedisTemplate<String, String> redisTemplate;
    
    public ApiKey generateApiKey(String clientName, Set<String> permissions) {
        String key = generateSecureKey();
        String keyHash = hashApiKey(key);
        
        ApiKey apiKey = ApiKey.builder()
            .keyHash(keyHash)
            .clientName(clientName)
            .permissions(permissions)
            .isActive(true)
            .createdAt(LocalDateTime.now())
            .expiresAt(LocalDateTime.now().plusMonths(6))
            .build();
            
        apiKeyRepository.save(apiKey);
        
        // Cache in Redis for fast lookup
        cacheApiKey(keyHash, apiKey);
        
        return apiKey;
    }
    
    private String generateSecureKey() {
        SecureRandom random = new SecureRandom();
        byte[] bytes = new byte[32];
        random.nextBytes(bytes);
        return Base64.getUrlEncoder().withoutPadding().encodeToString(bytes);
    }
    
    private String hashApiKey(String apiKey) {
        return DigestUtils.sha256Hex(apiKey);
    }
    
    public boolean validateApiKey(String apiKey, String requiredPermission) {
        String keyHash = hashApiKey(apiKey);
        
        // Check cache first
        ApiKey cachedKey = getCachedApiKey(keyHash);
        if (cachedKey != null) {
            return isValidKey(cachedKey, requiredPermission);
        }
        
        // Fallback to database
        Optional<ApiKey> dbKey = apiKeyRepository.findByKeyHash(keyHash);
        if (dbKey.isPresent()) {
            cacheApiKey(keyHash, dbKey.get());
            return isValidKey(dbKey.get(), requiredPermission);
        }
        
        return false;
    }
    
    private boolean isValidKey(ApiKey apiKey, String requiredPermission) {
        return apiKey.isActive() && 
               apiKey.getExpiresAt().isAfter(LocalDateTime.now()) &&
               apiKey.getPermissions().contains(requiredPermission);
    }
}
