## Input Validation & Sanitization

### 1. Request Validation
```java
@RestController
@Validated
public class CustomerController {
    
    @PostMapping("/api/v1/customers")
    public ResponseEntity<CustomerDTO> createCustomer(
            @Valid @RequestBody CreateCustomerRequest request) {
        
        // Additional custom validation
        validateCreateCustomerRequest(request);
        
        CustomerDTO customer = customerService.createCustomer(request);
        return ResponseEntity.status(HttpStatus.CREATED).body(customer);
    }
    
    private void validateCreateCustomerRequest(CreateCustomerRequest request) {
        // Check for SQL injection patterns
        if (containsSqlInjectionPattern(request.getFirstName()) ||
            containsSqlInjectionPattern(request.getLastName())) {
            throw new ValidationException("Invalid characters in name fields");
        }
        
        // Validate email domain against allowed list
        if (!isAllowedEmailDomain(request.getEmail())) {
            throw new ValidationException("Email domain not allowed");
        }
    }
    
    private boolean containsSqlInjectionPattern(String input) {
        String[] sqlKeywords = {"SELECT", "INSERT", "UPDATE", "DELETE", "DROP", "UNION", "SCRIPT"};
        String upperInput = input.toUpperCase();
        
        return Arrays.stream(sqlKeywords)
            .anyMatch(keyword -> upperInput.contains(keyword));
    }
}

// DTO validation annotations
public class CreateCustomerRequest {
    
    @NotBlank(message = "First name is required")
    @Size(min = 2, max = 50, message = "First name must be between 2 and 50 characters")
    @Pattern(regexp = "^[a-zA-Z\\s]*$", message = "First name can only contain letters and spaces")
    private String firstName;
    
    @NotBlank(message = "Last name is required")
    @Size(min = 2, max = 50, message = "Last name must be between 2 and 50 characters")
    @Pattern(regexp = "^[a-zA-Z\\s]*$", message = "Last name can only contain letters and spaces")
    private String lastName;
    
    @NotBlank(message = "Email is required")
    @Email(message = "Invalid email format")
    @Size(max = 255, message = "Email cannot exceed 255 characters")
    private String email;
    
    @Pattern(regexp = "^\\+?[1-9]\\d{1,14}$", message = "Invalid phone number format")
    private String phone;
    
    @Past(message = "Date of birth must be in the past")
