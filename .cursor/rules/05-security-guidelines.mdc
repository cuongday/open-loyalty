### 1. GDPR Compliance
```java
@Service
public class GdprComplianceService {
    
    public void exportCustomerData(String customerId) {
        // Export all customer data in portable format
        CustomerDataExport export = CustomerDataExport.builder()
            .personalData(getPersonalData(customerId))
            .transactionHistory(getTransactionHistory(customerId))
            .pointsHistory(getPointsHistory(customerId))
            .campaignHistory(getCampaignHistory(customerId))
            .build();
            
        // Generate JSON/CSV export
        generateDataExport(export, customerId);
    }
    
    public void deleteCustomerData(String customerId, DataDeletionRequest request) {
        // Implement right to be forgotten
        if (request.isHardDelete()) {
            // Complete data removal
            customerService.hardDeleteCustomer(customerId);
        } else {
            // Anonymization
            customerService.anonymizeCustomer(customerId);
        }
        
        // Log deletion for audit purposes
        auditService.logDataDeletion(customerId, request);
    }
    
    public ConsentRecord recordConsent(String customerId, ConsentType consentType, boolean granted) {
        ConsentRecord consent = ConsentRecord.builder()
            .customerId(customerId)
            .consentType(consentType)
            .granted(granted)
            .timestamp(LocalDateTime.now())
            .ipAddress(getCurrentIpAddress())
            .userAgent(getCurrentUserAgent())
            .build();
            
        return consentRepository.save(consent);
    }
}
