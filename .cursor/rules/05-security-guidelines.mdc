    // Constructors, getters, setters
}

// Audit logging aspect
@Aspect
@Component
@Slf4j
public class SecurityAuditAspect {
    
    private final SecurityAuditLogRepository auditLogRepository;
    
    @AfterReturning(pointcut = "@annotation(auditable)", returning = "result")
    public void logSuccessfulOperation(JoinPoint joinPoint, Auditable auditable, Object result) {
        logSecurityEvent(joinPoint, auditable, "SUCCESS", null);
    }
    
    @AfterThrowing(pointcut = "@annotation(auditable)", throwing = "exception")
    public void logFailedOperation(JoinPoint joinPoint, Auditable auditable, Exception exception) {
        logSecurityEvent(joinPoint, auditable, "FAILURE", exception.getMessage());
    }
    
    private void logSecurityEvent(JoinPoint joinPoint, Auditable auditable, String status, String error) {
        Authentication auth = SecurityContextHolder.getContext().getAuthentication();
        HttpServletRequest request = getCurrentHttpRequest();
        
        SecurityAuditLog auditLog = SecurityAuditLog.builder()
            .userId(auth != null ? auth.getName() : "ANONYMOUS")
            .action(auditable.action())
            .resource(auditable.resource())
            .ipAddress(getClientIpAddress(request))
            .userAgent(request.getHeader("User-Agent"))
            .timestamp(LocalDateTime.now())
            .status(status)
            .details(error)
            .build();
            
        auditLogRepository.save(auditLog);
    }
}

// Auditable annotation
@Target(ElementType.METHOD)
@Retention(RetentionPolicy.RUNTIME)
public @interface Auditable {
    String action();
    String resource();
}
