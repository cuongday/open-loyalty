### 2. Data Masking for Logs
```java
@Component
public class DataMaskingProcessor {
    
    private static final Pattern EMAIL_PATTERN = Pattern.compile(
        "\\b[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Z|a-z]{2,}\\b"
    );
    
    private static final Pattern PHONE_PATTERN = Pattern.compile(
        "\\b\\+?[1-9]\\d{1,14}\\b"
    );
    
    private static final Pattern CREDIT_CARD_PATTERN = Pattern.compile(
        "\\b(?:\\d{4}[-\\s]?){3}\\d{4}\\b"
    );
    
    public String maskSensitiveData(String content) {
        if (content == null) {
            return null;
        }
        
        String masked = content;
        
        // Mask email addresses
        masked = EMAIL_PATTERN.matcher(masked).replaceAll(m -> {
            String email = m.group();
            int atIndex = email.indexOf('@');
            if (atIndex > 2) {
                return email.substring(0, 2) + "***@" + email.substring(atIndex + 1);
            }
            return "***@" + email.substring(atIndex + 1);
        });
        
        // Mask phone numbers
        masked = PHONE_PATTERN.matcher(masked).replaceAll(m -> {
            String phone = m.group();
            if (phone.length() > 4) {
                return phone.substring(0, phone.length() - 4) + "****";
            }
            return "****";
        });
        
        // Mask credit card numbers
        masked = CREDIT_CARD_PATTERN.matcher(masked).replaceAll("****-****-****-****");
        
        return masked;
    }
}
