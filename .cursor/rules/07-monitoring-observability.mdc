### 3. Alert Integration with PagerDuty/Slack
```java
@Service
public class AlertingService {
    
    private final NotificationClient notificationClient;
    private final AlertRepository alertRepository;
    
    @EventListener
    public void handleCriticalAlert(CriticalAlertEvent event) {
        Alert alert = Alert.builder()
            .type(event.getAlertType())
            .severity(AlertSeverity.CRITICAL)
            .message(event.getMessage())
            .service(event.getServiceName())
            .timestamp(LocalDateTime.now())
            .build();
            
        alertRepository.save(alert);
        
        // Send to PagerDuty for critical alerts
        if (event.getSeverity() == AlertSeverity.CRITICAL) {
            notificationClient.sendPagerDutyAlert(alert);
        }
        
        // Send to Slack for all alerts
        notificationClient.sendSlackAlert(alert);
        
        // Check for alert escalation
        checkAlertEscalation(alert);
    }
    
    private void checkAlertEscalation(Alert alert) {
        List<Alert> recentAlerts = alertRepository.findRecentAlerts(
            alert.getService(), 
            Duration.ofMinutes(30)
        );
        
        if (recentAlerts.size() > 5) {
            // Escalate to management
            notificationClient.sendEscalationAlert(alert, recentAlerts);
        }
    }
}
