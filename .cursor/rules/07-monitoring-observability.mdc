## Alerting & Monitoring Dashboards

### 1. Prometheus Alerting Rules
```yaml
# alerts.yml
groups:
- name: loyalty.rules
  rules:
  - alert: HighErrorRate
    expr: rate(http_requests_total{status=~"5.."}[5m]) > 0.1
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: "High error rate detected"
      description: "Error rate is {{ $value }} errors per second"
      
  - alert: HighResponseTime
    expr: histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m])) > 2
    for: 10m
    labels:
      severity: critical
    annotations:
      summary: "High response time detected"
      description: "95th percentile response time is {{ $value }} seconds"
      
  - alert: LoyaltyPointsProcessingStalled
    expr: increase(loyalty_points_earned_total[10m]) == 0
    for: 15m
    labels:
      severity: warning
    annotations:
      summary: "Points processing appears stalled"
      description: "No points have been earned in the last 10 minutes"
      
  - alert: DatabaseConnectionIssues
    expr: up{job="loyalty-database"} == 0
    for: 1m
    labels:
      severity: critical
    annotations:
      summary: "Database connection down"
      description: "Cannot connect to loyalty database"
      
  - alert: RedisConnectionIssues
    expr: redis_up == 0
    for: 2m
    labels:
      severity: warning
    annotations:
      summary: "Redis connection issues"
      description: "Redis cache is unavailable"
```

