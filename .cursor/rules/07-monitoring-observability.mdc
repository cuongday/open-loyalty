@Configuration
public class TracingConfig {
    
    @Bean
    public Sampler customSampler() {
        return ProbabilitySampler.create(0.1f);
    }
    
    @Bean
    public SpanCustomizer spanCustomizer() {
        return span -> {
            span.tag("service.type", "loyalty");
            span.tag("service.version", getClass().getPackage().getImplementationVersion());
        };
    }
}

// Custom span annotations
@Component
public class TracingService {
    
    private final Tracer tracer;
    
    @NewSpan("customer-registration")
    public Customer registerCustomer(@SpanTag("customerId") String customerId, 
                                   RegisterCustomerRequest request) {
        
        Span span = tracer.nextSpan()
            .name("customer-registration")
            .tag("customer.email", request.getEmail())
            .tag("customer.segment", request.getSegment())
            .start();
            
        try (Tracer.SpanInScope ws = tracer.withSpanInScope(span)) {
            // Registration logic
            Customer customer = performRegistration(request);
            
            span.tag("registration.success", "true");
            span.tag("customer.level", customer.getLevel());
            
            return customer;
        } catch (Exception e) {
            span.tag("registration.success", "false");
            span.tag("error.message", e.getMessage());
            throw e;
        } finally {
            span.end();
        }
    }
    
    @NewSpan("points-calculation")
    public PointsCalculationResult calculatePoints(@SpanTag("customerId") String customerId,
                                                  @SpanTag("transactionId") String transactionId,
                                                  TransactionDetails transaction) {
        
        Span span = tracer.nextSpan()
            .name("points-calculation")
            .tag("transaction.amount", transaction.getAmount().toString())
            .tag("transaction.channel", transaction.getChannel())
            .start();
            
        try (Tracer.SpanInScope ws = tracer.withSpanInScope(span)) {
            PointsCalculationResult result = performPointsCalculation(customerId, transaction);
            
            span.tag("points.earned", String.valueOf(result.getPointsEarned()));
            span.tag("rules.applied", String.valueOf(result.getRulesApplied()));
            
            return result;
        } finally {
            span.end();
        }
    }
}
