# Monitoring & Observability

## Application Monitoring Stack

### 1. Metrics Collection with Micrometer & Prometheus
```yaml
# Application properties for metrics
management:
  endpoints:
    web:
      exposure:
        include: health,info,metrics,prometheus
  endpoint:
    health:
      show-details: always
  metrics:
    export:
      prometheus:
        enabled: true
    distribution:
      percentiles-histogram:
        http.server.requests: true
        spring.data.repository.invocations: true
      sla:
        http.server.requests: 50ms,100ms,200ms,500ms,1s,2s
```

```java
// Custom metrics configuration
@Configuration
public class MetricsConfig {
    
    @Bean
    public TimedAspect timedAspect(MeterRegistry registry) {
        return new TimedAspect(registry);
    }
    
    @Bean
    @ConditionalOnMissingBean
    public MeterFilter meterFilter() {
        return MeterFilter.deny(id -> {
            String name = id.getName();
            // Filter out noisy metrics
            return name.startsWith("jvm.threads.") || 
                   name.startsWith("process.") ||
                   name.startsWith("tomcat.sessions.");
        });
    }
    
    @Bean
    public Counter loyaltyTransactionCounter(MeterRegistry registry) {
        return Counter.builder("loyalty.transactions.total")
            .description("Total number of loyalty transactions processed")
            .register(registry);
    }
    
    @Bean
    public Timer loyaltyRuleExecutionTimer(MeterRegistry registry) {
        return Timer.builder("loyalty.rules.execution.time")
            .description("Time taken to execute loyalty rules")
            .register(registry);
    }
    
    @Bean
    public Gauge loyaltyActiveCustomersGauge(MeterRegistry registry, CustomerService customerService) {
        return Gauge.builder("loyalty.customers.active")
            .description("Number of active loyalty customers")
            .register(registry, customerService, CustomerService::getActiveCustomerCount);
    }
}
