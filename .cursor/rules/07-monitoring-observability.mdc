### 2. Health Checks Implementation
```java
@Component
public class LoyaltySystemHealthIndicator implements HealthIndicator {
    
    private final CustomerService customerService;
    private final AccountService accountService;
    private final CampaignService campaignService;
    private final RedisTemplate<String, String> redisTemplate;
    
    @Override
    public Health health() {
        Health.Builder status = Health.up();
        
        try {
            // Check database connectivity
            checkDatabaseHealth(status);
            
            // Check Redis connectivity
            checkRedisHealth(status);
            
            // Check business logic health
            checkBusinessLogicHealth(status);
            
            // Check external dependencies
            checkExternalDependencies(status);
            
        } catch (Exception e) {
            return Health.down(e).build();
        }
        
        return status.build();
    }
    
    private void checkDatabaseHealth(Health.Builder status) {
        try {
            long customerCount = customerService.getCustomerCount();
            status.withDetail("database.customers", customerCount);
            
            // Check recent transactions
            long recentTransactions = accountService.getRecentTransactionCount(Duration.ofMinutes(5));
            status.withDetail("database.recent_transactions", recentTransactions);
            
        } catch (Exception e) {
            status.down().withDetail("database.error", e.getMessage());
        }
    }
    
    private void checkRedisHealth(Health.Builder status) {
        try {
            String pingResult = redisTemplate.getConnectionFactory()
                .getConnection().ping();
            status.withDetail("redis.ping", pingResult);
            
            // Check cache hit rate
            double cacheHitRate = calculateCacheHitRate();
            status.withDetail("redis.cache_hit_rate", cacheHitRate);
            
        } catch (Exception e) {
            status.down().withDetail("redis.error", e.getMessage());
        }
    }
    
    private void checkBusinessLogicHealth(Health.Builder status) {
        try {
            // Test rule engine
            boolean ruleEngineHealthy = testRuleEngine();
            status.withDetail("rule_engine.healthy", ruleEngineHealthy);
            
            // Check campaign availability
            long activeCampaigns = campaignService.getActiveCampaignCount();
            status.withDetail("campaigns.active_count", activeCampaigns);
            
        } catch (Exception e) {
            status.down().withDetail("business_logic.error", e.getMessage());
        }
    }
}
```

### 3. Custom Metrics for Business KPIs
```java
@Component
public class BusinessMetricsCollector {
    
    private final MeterRegistry meterRegistry;
    private final Counter customerRegistrations;
    private final Counter pointsEarned;
    private final Counter pointsRedeemed;
    private final Counter campaignRedemptions;
    private final Timer transactionProcessingTime;
    
    public BusinessMetricsCollector(MeterRegistry meterRegistry) {
        this.meterRegistry = meterRegistry;
        
        this.customerRegistrations = Counter.builder("loyalty.customers.registrations")
            .description("Total customer registrations")
            .register(meterRegistry);
            
        this.pointsEarned = Counter.builder("loyalty.points.earned")
            .description("Total points earned by customers")
            .register(meterRegistry);
            
        this.pointsRedeemed = Counter.builder("loyalty.points.redeemed")
            .description("Total points redeemed by customers")
            .register(meterRegistry);
            
        this.campaignRedemptions = Counter.builder("loyalty.campaigns.redemptions")
            .description("Total campaign redemptions")
            .register(meterRegistry);
            
        this.transactionProcessingTime = Timer.builder("loyalty.transactions.processing.time")
            .description("Time to process loyalty transactions")
            .register(meterRegistry);
    }
    
    public void recordCustomerRegistration(String segment) {
        customerRegistrations.increment(Tags.of("segment", segment));
    }
    
    public void recordPointsEarned(BigDecimal points, String ruleType) {
        pointsEarned.increment(Tags.of("rule_type", ruleType), points.doubleValue());
    }
    
    public void recordPointsRedeemed(BigDecimal points, String campaignType) {
        pointsRedeemed.increment(Tags.of("campaign_type", campaignType), points.doubleValue());
    }
    
    public void recordCampaignRedemption(String campaignType, String customerLevel) {
        campaignRedemptions.increment(Tags.of(
            "campaign_type", campaignType,
            "customer_level", customerLevel
        ));
    }
    
    public Timer.Sample startTransactionTimer() {
        return Timer.start(meterRegistry);
    }
    
    public void recordTransactionTime(Timer.Sample sample, String transactionType, boolean success) {
        sample.stop(transactionProcessingTime.tags(
            "type", transactionType,
            "success", String.valueOf(success)
        ));
    }
}
