### 2. Log Aggregation with ELK Stack
```yaml
# Filebeat configuration for log shipping
filebeat.inputs:
- type: log
  enabled: true
  paths:
    - /var/log/loyalty-services/*.log
  fields:
    service: loyalty-platform
    environment: production
  fields_under_root: true
  
  # Multiline pattern for stack traces
  multiline.pattern: '^[0-9]{4}-[0-9]{2}-[0-9]{2}'
  multiline.negate: true
  multiline.match: after

output.elasticsearch:
  hosts: ["elasticsearch:9200"]
  index: "loyalty-logs-%{+yyyy.MM.dd}"
  
processors:
- add_host_metadata:
    when.not.contains.tags: forwarded
```

```java
// Log analysis utilities
@Component
public class LogAnalyticsService {
    
    private final ElasticsearchTemplate elasticsearchTemplate;
    
    public ErrorAnalysisReport analyzeErrors(LocalDateTime startTime, LocalDateTime endTime) {
        SearchQuery searchQuery = new NativeSearchQueryBuilder()
            .withQuery(QueryBuilders.boolQuery()
                .must(QueryBuilders.termQuery("level", "ERROR"))
                .must(QueryBuilders.rangeQuery("@timestamp")
                    .gte(startTime)
                    .lte(endTime)))
            .withAggregations(
                AggregationBuilders.terms("by_service").field("service"),
                AggregationBuilders.terms("by_error_type").field("exception.class"),
                AggregationBuilders.dateHistogram("over_time")
                    .field("@timestamp")
                    .calendarInterval(DateHistogramInterval.HOUR))
            .build();
            
        SearchResponse response = elasticsearchTemplate.search(searchQuery, Map.class);
        return parseErrorAnalysis(response);
    }
    
    public List<PerformanceAlert> detectPerformanceAnomalies() {
        // Query for slow requests
        SearchQuery slowRequestQuery = new NativeSearchQueryBuilder()
            .withQuery(QueryBuilders.boolQuery()
                .must(QueryBuilders.termQuery("message", "Performance metric"))
                .must(QueryBuilders.rangeQuery("duration")
                    .gte(5000))) // > 5 seconds
            .withSort(SortBuilders.fieldSort("@timestamp").order(SortOrder.DESC))
            .withPageable(PageRequest.of(0, 100))
            .build();
            
        return elasticsearchTemplate.search(slowRequestQuery, Map.class)
            .getContent()
            .stream()
            .map(this::mapToPerformanceAlert)
            .collect(Collectors.toList());
    }
}
